{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://glasswyrm.invalid/schemas/m14-vm-evidence-v1.json",
  "title": "Glasswyrm Milestone 14 QXL VM evidence summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "required_base_commit",
    "tested_commit",
    "profile",
    "passed",
    "failure_stage",
    "results",
    "evidence_errors"
  ],
  "properties": {
    "schema": {"const": "glasswyrm.m14-vm-evidence.v1"},
    "required_base_commit": {
      "const": "6864ea631d61636289a21c7d2d6655a17be0c004"
    },
    "tested_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "profile": {"const": "qxl-unsupported"},
    "passed": {"type": "boolean"},
    "failure_stage": {"type": "string"},
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "historical_default",
        "strict_m14",
        "strict_gles",
        "sanitizer",
        "component_builds",
        "api_consumers",
        "source_layout",
        "fake_drm_matrix",
        "simulated_headless_matrix",
        "raw_little_big",
        "gwout_vrr",
        "gwinfo_vrr",
        "vrr_policy_matrix",
        "sdl_vrr_reuse",
        "qxl_unsupported",
        "vt_replay",
        "gwm_replay",
        "compositor_replay",
        "restoration",
        "socket_cleanup",
        "archive_validation",
        "journal_evidence"
      ],
      "patternProperties": {
        "^[a-z0-9_]+$": {"enum": ["passed", "failed", "missing"]}
      }
    },
    "evidence_errors": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
