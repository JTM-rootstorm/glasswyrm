#!/usr/bin/env python3
"""Normalize a bounded Milestone 11 Glasswyrm X11 JSONL trace."""

import collections
import json
import pathlib
import sys


MAXIMUM_LINE_BYTES = 64 * 1024
MAXIMUM_TRACE_BYTES = 8 * 1024 * 1024
RECURRING_REQUESTS = frozenset(("QueryPointer", "QueryKeymap"))
PRESENCE_ONLY_REQUESTS = frozenset((
    "ClearArea", "CopyArea", "ImageText8", "PolyLine", "PutImage",
))
TRACE_GATED_REQUESTS = (
    "GrabButton", "UngrabButton", "GrabKey", "UngrabKey",
)
POST_M11_EXTENSION_NAMES = frozenset((
    "BIG-REQUESTS", "MIT-SHM", "Composite", "RANDR",
))


def fail(message):
    raise SystemExit(f"m11_trace_summarize: {message}")


def load_records(path):
    source_path = pathlib.Path(path)
    try:
        if source_path.stat().st_size > MAXIMUM_TRACE_BYTES:
            fail("trace exceeds 8 MiB")
        source = source_path.open("r", encoding="utf-8")
    except OSError as error:
        fail(str(error))

    records = []
    with source:
        for number, line in enumerate(source, 1):
            if len(line.encode("utf-8")) > MAXIMUM_LINE_BYTES:
                fail(f"trace line {number} exceeds 64 KiB")
            try:
                record = json.loads(line)
            except json.JSONDecodeError as error:
                fail(f"trace line {number}: {error.msg}")
            if not isinstance(record, dict):
                fail(f"trace line {number} is not an object")
            records.append(record)
    return records


def integer(value, field):
    if isinstance(value, bool) or not isinstance(value, int) or value < 0:
        fail(f"invalid {field}")
    return value


def m11_extension_name(value):
    # The M11 fixture predates stable trace names for extensions introduced by
    # M12. Preserve its historical OTHER class when newer servers annotate the
    # same client query more precisely.
    return "OTHER" if value in POST_M11_EXTENSION_NAMES else value


def summarize(records):
    requests = []
    replies = set()
    events = []
    accepted_clients = set()

    for record in records:
        direction = record.get("direction")
        client = integer(record.get("client"), "client")
        if direction == "connection":
            if record.get("outcome") == "accepted":
                accepted_clients.add(client)
            continue
        if direction == "request":
            integer(record.get("sequence"), "request sequence")
            integer(record.get("opcode"), "request opcode")
            integer(record.get("length"), "request length")
            if not isinstance(record.get("name"), str):
                fail("invalid request name")
            requests.append(record)
            continue
        if direction == "reply":
            replies.add((client, integer(record.get("sequence"),
                                         "reply sequence")))
            continue
        if direction == "event":
            event_type = integer(record.get("event_type"), "event type")
            events.append({"client": client, "event_type": event_type})
            continue
        if direction == "error":
            continue
        fail(f"unknown direction {direction!r}")

    histogram_requests = []
    presence_seen = set()
    for record in requests:
        name = record["name"]
        if name in PRESENCE_ONLY_REQUESTS:
            if name in presence_seen:
                continue
            presence_seen.add(name)
        histogram_requests.append(record)

    request_counts = collections.Counter(
        record["name"] for record in histogram_requests)
    opcode_counts = collections.Counter(
        str(record["opcode"]) for record in histogram_requests)
    error_counts = collections.Counter(
        record.get("error", "UnknownError") for record in requests
        if record.get("outcome") == "error")
    event_counts = collections.Counter(str(record["event_type"])
                                        for record in events)

    return {
        "schema": 1,
        "presence_normalized_requests": sorted(PRESENCE_ONLY_REQUESTS),
        "first_request_occurrence": list(dict.fromkeys(
            record["name"] for record in requests)),
        "request_histogram": dict(sorted(request_counts.items())),
        "opcode_histogram": dict(sorted(opcode_counts.items(),
                                        key=lambda item: int(item[0]))),
        "error_histogram": dict(sorted(error_counts.items())),
        "reply_requests": list(dict.fromkeys(
            record["name"] for record in requests
            if (record["client"], record["sequence"]) in replies)),
        "recurring_requests": sorted(
            name for name in RECURRING_REQUESTS if request_counts[name]),
        "extension_queries": list(dict.fromkeys(
            m11_extension_name(record["extension"]) for record in requests
            if record["name"] == "QueryExtension"
            and isinstance(record.get("extension"), str))),
        "unknown_opcodes": sorted({
            record["opcode"] for record in requests
            if record["name"] == "Unknown"}),
        "trace_gated_requests": {
            name: request_counts[name] for name in TRACE_GATED_REQUESTS
            if request_counts[name]
        },
        "event_histogram": dict(sorted(event_counts.items(),
                                       key=lambda item: int(item[0]))),
        "event_sequence": events,
        "application_connection_count": len(accepted_clients),
        "maximum_request_length": max(
            (record["length"] for record in requests), default=0),
    }


if len(sys.argv) != 2:
    fail("usage: m11_trace_summarize TRACE.jsonl")

json.dump(summarize(load_records(sys.argv[1])), sys.stdout, indent=2,
          separators=(",", ": "))
sys.stdout.write("\n")
