narrow_test_gwm() {
  local allow_rebuild=false
  if (($# > 0)); then
    [[ "$1" == "--allow-abi-rebuild" ]] || die "Unknown narrow-test option: $1"
    allow_rebuild=true
    shift
  fi
  require_no_extra_args "narrow-test gwm" "$@"
  init_artifacts
  local pretend_log="$ARTIFACTS_PATH_ABS/pretend-x11-wm-gwm.log"
  local report_log="$ARTIFACTS_PATH_ABS/narrow-test-gwm.log"
  local matches=()

  if ! portage_action pretend x11-wm/gwm; then
    printf 'Pretend failed; narrow update could not be evaluated.\n' >"$report_log" || return
    write_narrow_report false "$allow_rebuild" || return
    record_scenario "narrow-test-gwm" "failed" "$report_log"
    return 1
  fi

  while IFS= read -r package; do
    [[ -n "$package" ]] || continue
    if [[ ! " ${matches[*]} " == *" $package "* ]]; then
      matches+=("$package")
    fi
  done < <(
    awk '/^[[:space:]]*\[(ebuild|binary)[^]]*\]/ { print }' "$pretend_log" |
      grep -oE 'x11-base/(glasswyrmd|gwcomp)(-[0-9][^[:space:]]*|:[^[:space:]]*)?' |
      sed -E 's/(-[0-9].*|:.*)$//' || true
  )

  {
    printf 'Scenario: narrow-test-gwm\n'
    printf 'Package: x11-wm/gwm\n'
    if ((${#matches[@]} == 0)); then
      printf 'Unexpected rebuilds: none\n'
    else
      printf 'Detected rebuilds:\n'
      printf '  %s\n' "${matches[@]}"
    fi
  } >"$report_log" || return

  if ((${#matches[@]} > 0)) && [[ "$allow_rebuild" != "true" ]]; then
    write_narrow_report false false "${matches[@]}" || return
    record_scenario "narrow-test-gwm" "failed" "$report_log"
    cat "$report_log" >&2
    print_artifacts >&2
    return 1
  fi
  write_narrow_report true "$allow_rebuild" "${matches[@]}" || return
  record_scenario "narrow-test-gwm" "passed" "$report_log"
}

full_packaging_test() {
  local approved="$1"
  require_approval "full-packaging-test" "$approved"
  require_vm_domain
  is_true "$SNAPSHOT_ENABLED" || die "full-packaging-test requires snapshot.enabled = true to validate a fresh VM."
  init_artifacts
  SCENARIO_RECORDS=()
  local failure="" status=0

  if vm_reset true; then :; else status=$?; failure="reset"; fi
  if [[ -z "$failure" ]]; then
    if vm_boot; then :; else status=$?; failure="boot"; fi
  fi
  if [[ -z "$failure" ]]; then
    if push_overlay; then :; else status=$?; failure="push-overlay"; fi
  fi
  if [[ -z "$failure" ]]; then
    if register_overlay; then :; else status=$?; failure="register-overlay"; fi
  fi
  if [[ -z "$failure" ]]; then
    if portage_action metadata; then :; else status=$?; failure="metadata"; fi
  fi
  if [[ -z "$failure" ]]; then
    if portage_action pretend "$DEFAULT_PACKAGE"; then :; else status=$?; failure="pretend $DEFAULT_PACKAGE"; fi
  fi
  if [[ -z "$failure" ]]; then
    if portage_action emerge "$DEFAULT_PACKAGE"; then :; else status=$?; failure="emerge $DEFAULT_PACKAGE"; fi
  fi
  if [[ -z "$failure" ]]; then
    if narrow_test_gwm; then :; else status=$?; failure="narrow-test gwm"; fi
  fi
  if [[ -z "$failure" ]]; then
    if portage_action emerge x11-wm/gwm; then :; else status=$?; failure="emerge x11-wm/gwm"; fi
  fi
  if [[ -z "$failure" ]]; then
    if portage_action unmerge x11-wm/gwm; then :; else status=$?; failure="unmerge x11-wm/gwm"; fi
  fi

  if ! collect_logs; then
    if [[ -z "$failure" ]]; then
      failure="collect"
      status=1
    fi
  fi

  if [[ -n "$failure" ]]; then
    write_summary false "$failure" || return 1
    printf 'VM packaging test failed during: %s\n' "$failure" >&2
    print_artifacts >&2
    return "${status:-1}"
  fi
  write_summary true "" || return 1
  printf 'VM packaging test passed.\n'
  print_artifacts
}

run_named_scenario() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "scenario requires a fixed scenario name."
  shift
  case "$name" in
    register-overlay) require_no_extra_args "$name" "$@"; register_overlay ;;
    emerge-metadata) require_no_extra_args "$name" "$@"; portage_action metadata ;;
    pretend-glasswyrm) require_no_extra_args "$name" "$@"; portage_action pretend "$DEFAULT_PACKAGE" ;;
    emerge-glasswyrm) action_emerge "$DEFAULT_PACKAGE" "$@" ;;
    pretend-gwm) require_no_extra_args "$name" "$@"; portage_action pretend x11-wm/gwm ;;
    emerge-gwm) action_emerge x11-wm/gwm "$@" ;;
    unmerge-gwm) action_unmerge x11-wm/gwm "$@" ;;
    narrow-test-gwm) narrow_test_gwm "$@" ;;
    collect-logs) require_no_extra_args "$name" "$@"; collect_logs ;;
    full-packaging-test) action_full "$@" ;;
    milestone1-runtime-test) action_milestone1 "$@" ;;
    milestone2-runtime-test) action_milestone2 "$@" ;;
    milestone3-runtime-test) action_milestone3 "$@" ;;
    milestone4-runtime-test) action_milestone4 "$@" ;;
    milestone5-runtime-test) action_milestone5 "$@" ;;
    milestone6-runtime-test) action_milestone6 "$@" ;;
    milestone7-runtime-test) action_milestone7 "$@" ;;
    milestone8-runtime-test) action_milestone8 "$@" ;;
    milestone9-runtime-test) action_milestone9 "$@" ;;
    milestone10-runtime-test) action_milestone10 "$@" ;;
    milestone11-runtime-test) action_milestone11 "$@" ;;
    milestone12-runtime-test) action_milestone12 "$@" ;;
    milestone13-runtime-test) action_milestone13 "$@" ;;
    milestone14-runtime-test) action_milestone14 "$@" ;;
    milestone11-interactive-rerun) action_milestone11_interactive_rerun "$@" ;;
    *) die "Unknown scenario '$name'. Scenario names are fixed and cannot be paths." ;;
  esac
}

