doctor() {
  local failed=0 tool path
  for tool in bash ssh rsync virsh python3; do
    if command_exists "$tool"; then
      printf '[ok] %s\n' "$tool"
    else
      printf '[missing] %s\n' "$tool"
      failed=1
    fi
  done
  printf '[ok] TOML strategy: dependency-free parser for the fixed config schema\n'

  for path in \
    "$LOCAL_OVERLAY_PATH_ABS" \
    "$LOCAL_SOURCE_PATH_ABS" \
    "$GW_VM_DIR/config.example.toml" \
    "$REPO_ROOT/artifacts/vm"; do
    if [[ -e "$path" ]]; then
      printf '[ok] %s\n' "$path"
    else
      printf '[missing] %s\n' "$path"
      failed=1
    fi
  done

  if [[ -z "$VM_DOMAIN" ]]; then
    printf '[configure] No VM domain configured.\n'
    printf '%s\n' 'Set GLASSWYRM_VM_NAME or copy tools/gw-vm.d/config.example.toml to tools/gw-vm.d/config.toml and set [libvirt].domain.'
    failed=1
  else
    printf '[ok] VM domain: %s\n' "$VM_DOMAIN"
    milestone10_doctor || failed=1
  fi
  printf '[ok] SSH target: %s@%s:%s\n' "$SSH_USER" "$SSH_HOST" "$SSH_PORT"

  if mkdir -p "$ARTIFACTS_PATH_ABS" && [[ -w "$ARTIFACTS_PATH_ABS" ]]; then
    printf '[ok] artifacts writable: %s\n' "$ARTIFACTS_PATH_DISPLAY"
  else
    printf '[failed] artifacts not writable: %s\n' "$ARTIFACTS_PATH_DISPLAY"
    failed=1
  fi
  return "$failed"
}

