guest.ssh = $SSH_USER@$SSH_HOST:$SSH_PORT
guest.shared_overlay_path = $GUEST_OVERLAY_PATH
guest.shared_artifacts_path = $GUEST_ARTIFACTS_PATH
guest.shared_source_path = $GUEST_SOURCE_PATH
paths.overlay = $OVERLAY_PATH_DISPLAY
paths.artifacts = $ARTIFACTS_PATH_DISPLAY
