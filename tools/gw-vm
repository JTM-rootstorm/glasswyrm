main() {
  if [[ "${1:-}" == "--config" ]]; then
    (($# >= 2)) || die "--config requires a path."
    GW_VM_CONFIG_CLI="$2"
    shift 2
  fi

  local command="${1:-help}"
  (($# == 0)) || shift
  if [[ "$command" == "help" || "$command" == "--help" || "$command" == "-h" ]]; then
    require_no_extra_args "help" "$@"
    usage
    return 0
  fi

  load_config
  case "$command" in
    doctor) require_no_extra_args doctor "$@"; doctor ;;
    config) require_no_extra_args config "$@"; print_config ;;
    status) require_no_extra_args status "$@"; vm_status ;;
    boot) require_no_extra_args boot "$@"; vm_boot ;;
    shutdown) require_no_extra_args shutdown "$@"; vm_shutdown ;;
    reset)
      local approved
      approved="$(parse_yes_only "$@")"
      vm_reset "$approved"
      ;;
    push-overlay) require_no_extra_args push-overlay "$@"; push_overlay ;;
    push-source) require_no_extra_args push-source "$@"; push_source ;;
    register-overlay) require_no_extra_args register-overlay "$@"; register_overlay ;;
    metadata) require_no_extra_args metadata "$@"; portage_action metadata ;;
    pretend)
      (($# == 1)) || die "pretend requires exactly one package."
      validate_package "$1"
      portage_action pretend "$1"
      ;;
    emerge)
      (($# >= 1)) || die "emerge requires a package."
      local package="$1"
      shift
      action_emerge "$package" "$@"
      ;;
    unmerge)
      (($# >= 1)) || die "unmerge requires a package."
      local package="$1"
      shift
      action_unmerge "$package" "$@"
      ;;
    narrow-test)
      (($# >= 1)) || die "narrow-test requires a component name."
      [[ "$1" == "gwm" ]] || die "Only the 'gwm' narrow test is defined."
      shift
      narrow_test_gwm "$@"
      ;;
    collect) require_no_extra_args collect "$@"; collect_logs ;;
    full-packaging-test) action_full "$@" ;;
    milestone1-runtime-test) action_milestone1 "$@" ;;
    milestone2-runtime-test) action_milestone2 "$@" ;;
    milestone3-runtime-test) action_milestone3 "$@" ;;
    milestone4-runtime-test) action_milestone4 "$@" ;;
    milestone5-runtime-test) action_milestone5 "$@" ;;
    milestone6-runtime-test) action_milestone6 "$@" ;;
    milestone7-runtime-test) action_milestone7 "$@" ;;
    milestone8-runtime-test) action_milestone8 "$@" ;;
    milestone9-runtime-test) action_milestone9 "$@" ;;
    milestone10-runtime-test) action_milestone10 "$@" ;;
    milestone11-runtime-test) action_milestone11 "$@" ;;
    milestone12-runtime-test) action_milestone12 "$@" ;;
    milestone13-runtime-test) action_milestone13 "$@" ;;
    milestone14-runtime-test) action_milestone14 "$@" ;;
    milestone11-interactive-rerun) action_milestone11_interactive_rerun "$@" ;;
    scenario) run_named_scenario "$@" ;;
    *) die "Unknown command '$command'. Run './tools/gw-vm help'." ;;
  esac
}

main "$@"
